    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.0.0",
    "husky": "^9.1.4",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.3.5",
